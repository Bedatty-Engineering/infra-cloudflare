# ---------------------------------------------------------------------------
# .env.example — local environment for this stack
#
# Copy to .env and set values before running plan/apply:
#   cp .env.example .env
# ---------------------------------------------------------------------------

# Terraform Cloud / HCP Terraform authentication
TF_TOKEN_app_terraform_io=xxxxxx

# Cloudflare secrets
TF_VAR_cloudflare_api_token=xxxxxx
TF_VAR_cloudflare_account_id=xxxxxx
TF_VAR_cloudflare_zone_id=xxxxxx

# Custom hostname for this stack (Workers Custom Domain + DNS)
TF_VAR_domain=xxxxxx
